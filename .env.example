# Copy this file to ".env" and fill in your real key.
# The key is used ONLY by the backend (server/) and is never shipped to the browser.

# Your Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the Express backend listens on (optional, defaults to 3001).
PORT=3001
