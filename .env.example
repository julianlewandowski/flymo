# Copy this file to ".env" and fill in your real key.
# The key is used ONLY by the backend (server/) and is never shipped to the browser.

# Your Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the Express backend listens on (optional, defaults to 3001).
PORT=3001

# Optional: Infinite Flight Live API key, enables the "Pull from Infinite
# Flight" button which prefills the form from your active flight. Request a key
# by emailing hello@infiniteflight.com. Leave unset to disable the feature.
INFINITE_FLIGHT_API_KEY=
